{
  "name": "needle",
  "version": "1.0.0",
  "description": "Needle helps users find exact products from images, screenshots, URLs, and descriptions.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "telegram",
    "shopping",
    "openai",
    "exa",
    "product-search"
  ],
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.2.3",
    "exa-js": "^1.9.3",
    "express": "^5.2.1",
    "openai": "^6.10.0",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "stripe": "^22.3.0",
    "telegraf": "^4.16.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
